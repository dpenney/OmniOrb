# ESP32 Assistant Configuration
# Copy this file to .env and fill in your secrets

# Google Gemini API Key (Get at https://aistudio.google.com/)
GEMINI_API_KEY=your_api_key_here

# Email Configuration
EMAIL_SENDER=omnihub@penney.org
EMAIL_USERNAME=penney
EMAIL_PASSWORD=your_smtp_password_here
EMAIL_RECIPIENT=your_recipient_email_here
EMAIL_SMTP_SERVER=mail.kattare.com
EMAIL_SMTP_PORT=587

# Audio capture front-end. Selects a profile in config.py:
#   inmp441       - Raspberry Pi 4 + googlevoicehat-soundcard overlay (default)
#   inmp441_pi5   - Raspberry Pi 5 + i2s-mems-mic overlay (higher gain, left channel)
#   tachyon_codec - Particle Tachyon Audio Adapter (Qualcomm QCM6490 codec)
# On the Tachyon this MUST be tachyon_codec, and the systemd service needs a user
# PulseAudio session to capture (see install.sh: loginctl enable-linger + the
# XDG_RUNTIME_DIR/DBUS drop-in).
# install.sh sets this automatically based on detected hardware.
AUDIO_SOURCE=inmp441

# Hardware Overrides (Optional - only needed if not using config.py defaults)
# PIN_ROTARY_CLK=17
# PIN_ROTARY_DT=22

